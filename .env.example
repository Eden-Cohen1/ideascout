# ===========================================================================
# ideascout environment — copy to `.env` and fill in.
# Leave all AI/research provider keys BLANK to run in deterministic MOCK mode
# (the whole app works end-to-end with fake-but-stable data and no API spend).
# ===========================================================================

# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Database (Postgres) ----
POSTGRES_USER=ideascout
POSTGRES_PASSWORD=ideascout
POSTGRES_DB=ideascout
DATABASE_URL=postgresql://ideascout:ideascout@localhost:5432/ideascout?schema=public

# ---- Redis (BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ---- Encryption for per-project credentials (AES-256-GCM; base64 of 32 bytes) ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# ---- AI providers (default = openai; alternates = anthropic, gemini) ----
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- Research / web-search providers (default = tavily) ----
RESEARCH_DEFAULT_PROVIDER=tavily
TAVILY_API_KEY=

# ---- Web (Vite) ----
VITE_API_URL=/api

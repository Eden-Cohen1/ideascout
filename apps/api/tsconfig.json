{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    // Resolve @ideascout/shared via the built package (node_modules symlink ->
    // packages/shared/dist), NOT its source — keeps shared's .ts out of the API's
    // rootDir program. Build shared before typechecking/building the API.
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
